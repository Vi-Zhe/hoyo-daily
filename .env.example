# Скопируй в .env и заполни. Все секреты в одном файле. .env в .gitignore — в репо не попадёт.

# Куки HoYoLab — в одну строку (рекомендуемый способ хранения куки):
HOYO_COOKIES=
# формат: ltoken_v2=ЗНАЧ; ltuid_v2=ЗНАЧ; cookie_token_v2=ЗНАЧ; account_mid_v2=ЗНАЧ
# (ltoken_v2/ltuid_v2 — с hoyolab.com; cookie_token_v2/account_mid_v2 — с account.hoyoverse.com)

# Уведомления (опционально):
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
