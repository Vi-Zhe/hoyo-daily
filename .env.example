# Скопируй в .env и заполни нужное (всё опционально).
# Discord: вебхук канала (Server Settings -> Integrations -> Webhooks).
DISCORD_WEBHOOK=
# Telegram: токен бота от @BotFather и твой chat_id (узнать у @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Можно держать куки здесь вместо cookies.txt:
# HOYO_COOKIES=ltoken_v2=...; ltuid_v2=...; cookie_token_v2=...; account_mid_v2=...
